language js(typescript, jsx)

or {
    `pipe($args)`,
    `$target.pipe($args)`
} where {
    or {
        $args <: contains `pipe($_)` as $nested,
        $args <: contains `$inner.pipe($_)` as $nested
    },
    register_diagnostic(
        span = $nested,
        message = "Rule: avoid nested pipe() chains. Why: they hide sequencing. Fix: refactor into one flat pipeline with a single decision point.",
        severity = "error"
    )
}
